{
  "id": "jeeves",
  "model": {
    "primary": "amazon-bedrock/global.anthropic.claude-haiku-4-5-20251001-v1:0"
  },
  "tools": {
    "allow": [
      "vault__*",
      "agentvault__*",
      "read",
      "write",
      "edit",
      "memory_search",
      "memory_get",
      "web_search",
      "web_fetch",
      "exec",
      "sessions_spawn",
      "subagents",
      "fastmail__list_folders",
      "fastmail__search_email",
      "fastmail__read_email",
      "fastmail__list_calendars",
      "fastmail__search_events",
      "fastmail__create_event",
      "fastmail__update_event",
      "fastmail__delete_event"
    ]
  },
  "contextLimits": {
    "toolResultMaxChars": 4000
  }
}
